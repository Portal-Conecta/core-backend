# Spring
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# Maven / GitHub Packages
MAVEN_USERNAME=seu-usuario-github
MAVEN_PASSWORD=<token-com-read-packages>

# Database
POSTGRES_DB=portal_conecta
POSTGRES_USER=portal_conecta
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_PORT=5432
DB_URL=jdbc:postgresql://postgres:5432/portal_conecta
DB_USERNAME=portal_conecta
DB_PASSWORD=troque-esta-senha
DB_DRIVER=org.postgresql.Driver
FLYWAY_BASELINE_ON_MIGRATE=true

# JWT
JWT_SECRET=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# RabbitMQ
RABBITMQ_ENABLED=true
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_NOTIFICATIONS_EXCHANGE=notifications.exchange
RABBITMQ_NOTIFICATIONS_QUEUE=notifications.dispatch.q
RABBITMQ_NOTIFICATIONS_DLQ=notifications.dispatch.dlq
RABBITMQ_NOTIFICATIONS_ROUTING_KEY=notification.requested
RABBITMQ_RETRY_ENABLED=true
RABBITMQ_RETRY_MAX_ATTEMPTS=3
RABBITMQ_RETRY_INITIAL_INTERVAL=1000
RABBITMQ_RETRY_MULTIPLIER=2
RABBITMQ_RETRY_MAX_INTERVAL=10000
RABBITMQ_DEFAULT_REQUEUE_REJECTED=false

# SMTP (opcional) - envio de e-mail de ativacao de conta
# Deixe estas variaveis comentadas para rodar sem SMTP: a criacao de usuario
# continua funcionando normalmente e o Core apenas registra um warning ao
# tentar enviar o e-mail.
#SPRING_MAIL_HOST=localhost
#SPRING_MAIL_PORT=1025
#SPRING_MAIL_USERNAME=
#SPRING_MAIL_PASSWORD=
#SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
#SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false

# Ativacao de conta
ACCOUNT_ACTIVATION_BASE_URL=http://localhost:5173/ativar-conta
ACCOUNT_ACTIVATION_MAIL_FROM=no-reply@portal-conecta.local